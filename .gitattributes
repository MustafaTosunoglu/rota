# Normalize all text files to LF in the repository.
# This keeps line endings consistent across WSL/Linux/macOS and Windows.
* text=auto eol=lf

# Scripts that MUST stay LF (executed on Linux / in containers)
*.sh    text eol=lf
gradlew text eol=lf

# Windows-only scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.jar   binary
*.zip   binary
*.gz    binary
*.pdf   binary
